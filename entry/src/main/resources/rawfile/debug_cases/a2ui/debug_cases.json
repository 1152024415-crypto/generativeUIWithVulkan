[
  {
    "name": "✅A2UI 天气卡片-Row 布局",
    "mode": "portrait",
    "description": "A2UI 格式的天气卡片，图片在左文字在右",
    "dsl": {
      "version": "v0.9",
      "updateComponents": {
        "surfaceId": "main",
        "components": [
          {
            "id": "root",
            "component": "Column",
            "styles": {
              "background-color": "#E3F2FD",
              "padding": "20px 20px 20px 20px",
              "justify-content": "center",
              "align-items": "center"
            },
            "children": ["weather_card"]
          },
          {
            "id": "weather_card",
            "component": "Card",
            "styles": {
              "background-color": "#90CAF9",
              "border-radius": "30px",
              "padding": "30px 30px 30px 30px"
            },
            "child": "card_content"
          },
          {
            "id": "card_content",
            "component": "Row",
            "styles": {
              "align-items": "center",
              "justify-content": "center"
            },
            "children": ["weather_img", "text_group"]
          },
          {
            "id": "text_group",
            "component": "Column",
            "styles": {
              "padding": "0px 0px 0px 30px",
              "justify-content": "center"
            },
            "children": ["city_text", "temp_text"]
          },
          {
            "id": "city_text",
            "component": "Text",
            "text": "北京市 晴朗",
            "variant": "h2",
            "styles": {
              "color": "#0D47A1"
            }
          },
          {
            "id": "temp_text",
            "component": "Text",
            "text": "26°C",
            "variant": "h1",
            "styles": {
              "color": "#E65100"
            }
          },
          {
            "id": "weather_img",
            "component": "Image",
            "url": "weather/sun.png",
            "styles": {
              "width": "250px",
              "height": "250px"
            }
          }
        ]
      }
    }
  },
  {
