          {
            "id": "poem_title",
            "component": "Text",
            "text": "静夜思",
            "variant": "h2",
            "styles": {
              "color": "#4E342E"
            }
          },
          {
            "id": "poem_body",
            "component": "Text",
            "text": "床前明月光，\n疑是地上霜。\n举头望明月，\n低头思故乡。",
            "variant": "h4",
            "styles": {
              "color": "#212121"
            }
          },
          {
            "id": "poem_author",
            "component": "Text",
            "text": "——李白",
            "variant": "caption",
            "styles": {
              "color": "#757575"
            }
          }
        ]
      }
    }
  },
